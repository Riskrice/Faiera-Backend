# ====================================
# Faiera - Environment Configuration
# ====================================

# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=faiera

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ====================================
# External Services (Add when ready)
# ====================================

# Bunny.net Video Stream
BUNNY_API_KEY=
BUNNY_LIBRARY_ID=
BUNNY_SIGNING_KEY=
BUNNY_PULL_ZONE=

# Google Meet / Calendar OAuth2
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/sessions/google/callback
GOOGLE_CALENDAR_ID=primary

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Fawaterk Payment (Legacy)
# FAWATERK_API_KEY=
# FAWATERK_WEBHOOK_SECRET=

# ====================================
# Active Payment Provider
# Options: 'paymob' (default) or 'fawaterk'
# ====================================
ACTIVE_PAYMENT_PROVIDER=paymob

# ====================================
# Paymob Payment Gateway
# Get credentials from: https://accept.paymob.com/portal2/en/login
# ====================================
PAYMOB_SECRET_KEY=                       # Secret Key from Dashboard → Settings
PAYMOB_PUBLIC_KEY=                       # Public Key from Dashboard → Settings
PAYMOB_HMAC_SECRET=                      # HMAC Secret from Dashboard → Settings
PAYMOB_BASE_URL=https://accept.paymob.com

# Integration IDs (from Dashboard → Payment Integrations)
# Set to 0 or leave empty to disable a payment method
PAYMOB_CARD_INTEGRATION_ID=              # Cards (Visa, Mastercard, Amex)
PAYMOB_WALLET_INTEGRATION_ID=           # Mobile Wallets (Vodafone Cash, Orange, etc.)
PAYMOB_KIOSK_INTEGRATION_ID=            # Kiosk payments (Aman, Masary, Fawry)
PAYMOB_VALU_INTEGRATION_ID=             # BNPL (vaLU, Sympl, Souhoola, Halan)
PAYMOB_APPLEPAY_INTEGRATION_ID=         # Apple Pay
PAYMOB_GOOGLEPAY_INTEGRATION_ID=        # Google Pay
